---
import type { CodingFont } from "../lib/codingFonts";
import { getFontDisplayName, getFontStyle } from "../lib/fontFeatures";
import { getFontPath } from "../lib/routes";
import ButtonGroup from "./ButtonGroup.astro";
import CodeSpecimen from "./CodeSpecimen.astro";
import IconButton from "./IconButton.astro";

type Props = {
  /** Prefix for the JS-addressable element ids: `${prefix}-name`, `-visit`, etc. */
  prefix: string;
  font: CodingFont;
  /** Root element id (used to show/hide the compare column). */
  id?: string;
  hidden?: boolean;
  /** Render a close button. */
  showClose?: boolean;
  /** Start the close button hidden (the left view only shows it while comparing). */
  closeHidden?: boolean;
};

const {
  prefix,
  font,
  id,
  hidden = false,
  showClose = false,
  closeHidden = false,
} = Astro.props;
const actionClass = "h-9 gap-2 px-3";
---

<div id={id} hidden={hidden} class="flex min-h-0 flex-col gap-4">
  <div class="flex min-h-9 items-center justify-between gap-3">
    <span
      id={`${prefix}-name`}
      data-family={font.family}
      style={getFontStyle(font)}
      class="truncate text-lg font-bold whitespace-nowrap"
    >
      {getFontDisplayName(font)}
    </span>
    <ButtonGroup>
      <IconButton
        id={`${prefix}-visit`}
        href={font.siteUrl}
        target="_blank"
        hidden={font.isSystemFont}
        divider
        class={actionClass}
        icon="icon-[lucide--external-link]"
        title="Visit site"
      />
      <IconButton
        id={`${prefix}-download`}
        href={font.downloadUrl}
        hidden={font.isSystemFont}
        divider
        class={actionClass}
        icon="icon-[lucide--download]"
        title="Download"
      />
      <IconButton
        id={`${prefix}-maximize`}
        href={getFontPath(font.family)}
        divider={showClose}
        class={actionClass}
        icon="icon-[lucide--maximize-2]"
        title="Open font page"
      />
      {
        showClose && (
          <IconButton
            as="button"
            id={`${prefix}-close`}
            hidden={closeHidden}
            class={`${actionClass} cursor-pointer`}
            icon="icon-[lucide--x]"
            title="Close comparison"
          />
        )
      }
    </ButtonGroup>
  </div>
  <CodeSpecimen
    id={`${prefix}-specimen`}
    font={font}
    class="min-h-0 overflow-hidden rounded-lg border border-slate-300 dark:border-slate-700"
  />
</div>
