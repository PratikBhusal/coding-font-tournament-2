---
// Filters the static font table (rows carry data-search) — no framework, no shared store.
---

<input
  id="font-search"
  class="border-surface-300 dark:border-surface-700 dark:bg-surface-900 min-h-9 w-full max-w-xl rounded-md border bg-white px-4 py-2"
  type="search"
  placeholder="Search ..."
/>

<script>
  import { initSearch } from "../scripts/searchBox";
  initSearch();
  document.addEventListener("astro:page-load", initSearch);
</script>
