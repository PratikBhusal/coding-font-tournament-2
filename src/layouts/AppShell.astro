---
type Props = {
  /** Open the sidebar by default on every viewport (still user-toggleable). */
  sidebarDefaultOpen?: boolean;
  /** Optional test hook placed on the <aside>. */
  sidebarTestId?: string;
};

const { sidebarDefaultOpen = false, sidebarTestId } = Astro.props;
---

<div
  class="grid h-dvh grid-rows-[auto_auto_minmax(0,1fr)] bg-slate-50 text-slate-950 dark:bg-slate-950 dark:text-slate-100"
>
  <slot name="header" />
  <slot name="controls" />
  <div class="relative flex min-h-0 min-w-0">
    <aside
      id="app-sidebar"
      data-testid={sidebarTestId}
      data-default-open={sidebarDefaultOpen ? "1" : "0"}
      class="relative z-20 min-w-0 overflow-hidden"
      style={`width: ${sidebarDefaultOpen ? "clamp(12rem, 33vw, 100vw)" : "0px"}`}
    >
      <div
        class="absolute inset-0 flex flex-col gap-4 overflow-auto border-r border-slate-300 bg-slate-100 p-4 pr-5 dark:border-slate-700 dark:bg-slate-900"
      >
        <slot name="sidebar" />
        <button
          id="app-sidebar-resize"
          type="button"
          aria-label="Resize sidebar"
          title="Drag to resize. Double-click to reset width."
          class="group absolute top-0 right-0 hidden h-full w-3 cursor-col-resize touch-none lg:block"
        >
          <span
            class="absolute top-0 right-0 h-full w-1 bg-slate-300 group-hover:bg-blue-500 group-active:bg-blue-600 dark:bg-slate-600"
          ></span>
        </button>
      </div>
    </aside>
    <main class="min-h-0 min-w-0 flex-1 overflow-hidden"><slot /></main>
  </div>
</div>

<script>
  import { initSidebar } from "../scripts/appShellSidebar";
  initSidebar();
  document.addEventListener("astro:page-load", initSidebar);
</script>
