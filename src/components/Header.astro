---
import { withBase } from "../lib/routes";
import IconButton from "./IconButton.astro";
import NavLink from "./NavLink.astro";

type Props = {
  path?: string;
  canToggleSidebar?: boolean;
};

const { path = "/", canToggleSidebar = true } = Astro.props;

const navItems = [
  { label: "Tournament", to: "/" },
  { label: "Browse", to: "/browse" },
];

const toggleClass =
  "h-9 w-9 cursor-pointer justify-center rounded-md border border-slate-300 bg-white transition active:scale-95 active:bg-slate-200 dark:border-slate-700 dark:bg-slate-950 dark:active:bg-slate-700";
---

<header
  class="z-30 flex items-center justify-between gap-4 border-b border-slate-300 bg-slate-100 p-4 dark:border-slate-700 dark:bg-slate-900"
>
  <div class="flex items-center gap-3">
    <div class="relative md:hidden">
      <IconButton
        as="button"
        id="app-nav-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        title="Menu"
        class={toggleClass}
        icon="icon-[lucide--menu]"
      />
      <nav
        id="app-nav-menu"
        hidden
        class="absolute top-full left-0 z-40 mt-2 flex min-w-40 flex-col overflow-hidden rounded-md border border-slate-300 bg-white font-mono font-semibold shadow-lg dark:border-slate-700 dark:bg-slate-950"
      >
        {
          navItems.map((item) => (
            <NavLink
              href={withBase(item.to)}
              active={path === item.to}
              class="px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-800"
              activeClass="bg-slate-100 dark:bg-slate-800"
            >
              {item.label}
            </NavLink>
          ))
        }
      </nav>
    </div>
    {
      canToggleSidebar && (
        <IconButton
          as="button"
          id="app-menu-toggle"
          aria-label="Toggle sidebar"
          title="Toggle sidebar"
          class={toggleClass}
          icon="icon-[lucide--settings]"
        />
      )
    }
  </div>

  <nav class="hidden items-center gap-2 font-mono text-lg font-semibold md:flex">
    {
      navItems.map((item) => (
        <NavLink
          href={withBase(item.to)}
          active={path === item.to}
          class="px-3 py-1"
          activeClass="before:content-['<'] after:content-['>']"
        >
          {item.label}
        </NavLink>
      ))
    }
  </nav>

  <IconButton
    as="button"
    id="app-theme-toggle"
    aria-label="Toggle theme"
    title="Toggle light/dark theme"
    class="h-9 w-9 justify-center rounded-md border border-slate-300 bg-white text-slate-900 transition active:scale-95 active:bg-slate-200 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:active:bg-slate-700"
    icon="icon-[lucide--swatch-book]"
  />
</header>

<script>
  import { initHeader } from "../scripts/header";
  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
