---
import { withBase } from "../lib/routes";
import IconButton from "./IconButton.astro";
import NavLink from "./NavLink.astro";

type Props = {
  path?: string;
  canToggleSidebar?: boolean;
};

const { path = "/", canToggleSidebar = true } = Astro.props;

const navItems = [
  { label: "Tournament", to: "/" },
  { label: "Browse", to: "/browse" },
];

const toggleClass =
  "h-9 w-9 cursor-pointer justify-center rounded-md border border-surface-300 bg-white transition-transform active:scale-95 active:bg-surface-200 dark:border-surface-700 dark:bg-surface-900 dark:active:bg-surface-700";
---

<header
  class="border-surface-300 bg-surface-100 dark:border-surface-700 dark:bg-surface-900 z-30 flex items-center justify-between gap-4 border-b p-4"
>
  <div class="flex items-center gap-3">
    <div class="relative h-9 w-9 md:hidden">
      <div
        aria-hidden="true"
        class={`pointer-events-none inline-flex items-center ${toggleClass}`}
      >
        <span class="icon-[lucide--menu] h-5 w-5"></span>
      </div>
      <select
        id="app-nav-select"
        aria-label="Navigation"
        class="absolute inset-0 h-9 w-9 cursor-pointer opacity-0"
      >
        {
          navItems.map((item) => (
            <option value={withBase(item.to)} selected={path === item.to}>
              {item.label}
            </option>
          ))
        }
      </select>
    </div>
    {
      canToggleSidebar && (
        <IconButton
          as="button"
          id="app-menu-toggle"
          aria-label="Toggle sidebar"
          title="Toggle sidebar"
          class={toggleClass}
          icon="icon-[lucide--settings]"
        />
      )
    }
  </div>

  <nav
    class="hidden items-center gap-2 font-mono text-lg font-semibold md:flex"
  >
    {
      navItems.map((item) => (
        <NavLink
          href={withBase(item.to)}
          active={path === item.to}
          class="px-3 py-1"
          activeClass="before:content-['<'] after:content-['>']"
        >
          {item.label}
        </NavLink>
      ))
    }
  </nav>

  <IconButton
    as="button"
    id="app-theme-toggle"
    aria-label="Toggle theme"
    title="Toggle light/dark theme"
    class="border-surface-300 text-surface-900 active:bg-surface-200 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:active:bg-surface-700 h-9 w-9 justify-center rounded-md border bg-white transition-transform active:scale-95"
    icon="icon-[lucide--swatch-book]"
  />
</header>

<script>
  import { initHeader } from "../scripts/header";
  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
