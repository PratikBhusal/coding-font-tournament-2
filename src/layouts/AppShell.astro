---
type Props = {
  /** Open the sidebar by default on every viewport (still user-toggleable). */
  sidebarDefaultOpen?: boolean;
  /** Optional test hook placed on the <aside>. */
  sidebarTestId?: string;
};

const { sidebarDefaultOpen = false, sidebarTestId } = Astro.props;
---

<div
  class="bg-surface-50 text-surface-900 dark:bg-surface-900 dark:text-surface-100 grid h-dvh grid-rows-[auto_auto_minmax(0,1fr)]"
>
  <slot name="header" />
  <slot name="controls" />
  <div class="relative flex h-full min-h-0 min-w-0 overflow-hidden">
    <aside
      id="app-sidebar"
      data-testid={sidebarTestId}
      data-default-open={sidebarDefaultOpen ? "1" : "0"}
      class="relative z-20 h-full min-w-0 shrink-0 overflow-hidden"
      style={`width: ${sidebarDefaultOpen ? "clamp(12rem, 33vw, 99vw)" : "0px"}`}
    >
      <div
        id="app-sidebar-scroll"
        class="border-surface-300 bg-surface-100 dark:border-surface-700 dark:bg-surface-900 absolute inset-0 flex [scrollbar-width:thin] flex-col gap-4 overflow-auto border-r p-4 pr-5"
      >
        <slot name="sidebar" />
      </div>
      <button
        id="app-sidebar-resize"
        type="button"
        aria-label="Resize sidebar"
        title="Drag to resize. Double-click to reset width."
        class="group absolute top-0 right-0 hidden h-full w-3 cursor-col-resize touch-none lg:block"
      >
        <span
          class="group-hover:bg-primary-500 group-active:bg-primary-600 bg-surface-300 dark:bg-surface-600 absolute top-0 right-0 h-full w-1"
        ></span>
      </button>
    </aside>
    <main class="min-h-0 min-w-0 flex-1 overflow-hidden"><slot /></main>
  </div>
</div>

<script>
  import { initSidebar } from "../scripts/appShellSidebar";
  initSidebar();
  document.addEventListener("astro:page-load", initSidebar);

  // Preserve the sidebar's scroll position across view-transition navigations
  // (e.g. clicking a Compare link). Capture it before the swap, then restore it on
  // page-load: the aside is server-rendered collapsed (width 0) and only opened by
  // initSidebar on astro:page-load, so restoring earlier would clamp to 0 (no laid-out
  // height). The rAF waits for that width/layout to apply. This page-load listener is
  // registered after initSidebar's, so it runs once the sidebar is open.
  let savedSidebarScroll = 0;
  document.addEventListener("astro:before-swap", () => {
    savedSidebarScroll =
      document.getElementById("app-sidebar-scroll")?.scrollTop ?? 0;
  });
  document.addEventListener("astro:page-load", () => {
    requestAnimationFrame(() => {
      const el = document.getElementById("app-sidebar-scroll");
      if (el) el.scrollTop = savedSidebarScroll;
    });
  });
</script>
