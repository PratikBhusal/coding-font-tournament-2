---
import type { CodingFont } from "../lib/codingFonts";
import { getFontDisplayName, getFontStyle } from "../lib/fontFeatures";
import { getFontPath } from "../lib/routes";
import ButtonGroup from "./ButtonGroup.astro";
import IconButton from "./IconButton.astro";

type Props = {
  font: CodingFont;
  maximizeHref?: string;
};

const { font, maximizeHref } = Astro.props;
const displayName = getFontDisplayName(font);
const nameStyle = getFontStyle(font);
---

<div class="flex min-h-9 items-center justify-between gap-3">
  {
    font.isSystemFont ? (
      <span
        class="truncate text-lg font-bold whitespace-nowrap"
        style={nameStyle}
      >
        {displayName}
      </span>
    ) : (
      <a
        class="truncate text-lg font-bold whitespace-nowrap hover:underline"
        style={nameStyle}
        href={getFontPath(font.family)}
      >
        {displayName}
      </a>
    )
  }
  <ButtonGroup>
    {
      !font.isSystemFont && (
        <>
          <IconButton
            href={font.siteUrl}
            target="_blank"
            divider
            class="h-9 gap-2 px-3"
            icon="icon-[lucide--external-link]"
            label={`Visit ${displayName}`}
            labelClass="hidden 2xl:block"
            title={`Visit ${displayName}`}
          />
          <IconButton
            href={font.downloadUrl}
            divider
            class="h-9 gap-2 px-3"
            icon="icon-[lucide--download]"
            label={`Download ${displayName}`}
            labelClass="hidden 2xl:block"
            title={`Download ${displayName}`}
          />
        </>
      )
    }
    {
      maximizeHref && (
        <IconButton
          href={maximizeHref}
          class="h-9 px-3"
          icon="icon-[lucide--maximize-2]"
          title="Open font page"
        />
      )
    }
  </ButtonGroup>
</div>
