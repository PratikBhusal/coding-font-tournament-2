---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppShell from "../layouts/AppShell.astro";
import Header from "../components/Header.astro";
import Controls from "../components/Controls.astro";
import SearchBox from "../components/SearchBox.astro";
import FontTable from "../components/FontTable.astro";
import FontHeader from "../components/FontHeader.astro";
import Specimen from "../components/Specimen.astro";
import CodeSpecimen from "../components/CodeSpecimen.astro";
import codingFonts from "../lib/codingFonts";
import { getFontDisplayName } from "../lib/fontFeatures";
import { getFontSlug, withBase } from "../lib/routes";

export function getStaticPaths() {
  return codingFonts.map((font) => ({
    params: { slug: getFontSlug(font.family) },
    props: { font },
  }));
}

const { font } = Astro.props;
const fontName = getFontDisplayName(font);
---

<BaseLayout
  title={font.displayName ?? font.family ?? "Coding Font"}
  description={`Preview ${fontName} with live, syntax-highlighted code specimens, then compare it against other coding fonts.`}
>
  <AppShell>
    <Header slot="header" path={`/${getFontSlug(font.family)}`} />
    <Controls slot="controls" />
    <div slot="sidebar" class="flex flex-col gap-4">
      <ol
        class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400"
      >
        <li>
          <a
            class="text-blue-700 underline dark:text-blue-300"
            href={withBase("/browse")}>Browse</a>
        </li>
        <li aria-hidden>&rsaquo;</li>
        <li>{getFontDisplayName(font)}</li>
      </ol>
      <h2 class="text-2xl font-bold">{getFontDisplayName(font)}</h2>
      <p>{font.variants.length} styles</p>
      {
        !font.isSystemFont && (
          <div class="flex flex-wrap gap-2">
            {font.variants.map((variant) => (
              <a
                href={font.files[variant]}
                target="_blank"
                class="rounded bg-slate-200 px-2 py-1 font-mono text-sm dark:bg-slate-800"
              >
                {variant}
              </a>
            ))}
          </div>
        )
      }
      <Specimen font={font} />
      {font.variants.includes("italic") && <Specimen font={font} italic />}
      {
        !font.isSystemFont && (
          <div class="@container flex flex-wrap gap-2 text-sm">
            <a
              href={font.downloadUrl}
              title={font.downloadUrl}
              class="flex flex-1 cursor-pointer items-center justify-center gap-2 rounded-md border border-slate-300 px-3 py-2 transition hover:bg-slate-200 active:scale-95 active:bg-slate-300 @max-xs:basis-full dark:border-slate-700 dark:hover:bg-slate-800 dark:active:bg-slate-700"
            >
              <span class="icon-[lucide--download] h-4 w-4 shrink-0" />
              <span class="truncate">Download Font</span>
            </a>
            <a
              href={font.siteUrl}
              target="_blank"
              title={font.siteUrl}
              class="flex flex-1 cursor-pointer items-center justify-center gap-2 rounded-md border border-slate-300 px-3 py-2 transition hover:bg-slate-200 active:scale-95 active:bg-slate-300 @max-xs:basis-full dark:border-slate-700 dark:hover:bg-slate-800 dark:active:bg-slate-700"
            >
              <span class="icon-[lucide--external-link] h-4 w-4 shrink-0" />
              <span class="truncate">Website URL</span>
            </a>
          </div>
        )
      }
      <hr class="border-slate-300 dark:border-slate-700" />
      <SearchBox />
      <FontTable
        fonts={codingFonts}
        baseFont={font}
        activeFamily={font.family}
      />
    </div>

    <div class="grid h-full grid-cols-1 gap-4 p-4 md:grid-cols-2">
      <div class="flex min-h-0 flex-col gap-4 md:col-span-2">
        <FontHeader font={font} />
        <CodeSpecimen
          font={font}
          class="min-h-0 overflow-hidden rounded-lg border border-slate-300 dark:border-slate-700"
        />
      </div>
    </div>
  </AppShell>
</BaseLayout>
