---
import type { CodingFont } from "../lib/codingFonts";
import { getFontDisplayName, getFontStyle } from "../lib/fontFeatures";
import {
  getFontTableCompareHref,
  getFontTableSearchValue,
  getSelectableFontTableRowAttrs,
  shouldShowFontTableCompareLink,
} from "../lib/fontTable";
import { getFontPath, getFontSlug } from "../lib/routes";
import ButtonGroup from "./ButtonGroup.astro";
import IconButton from "./IconButton.astro";

type Props = {
  fonts: CodingFont[];
  baseFont?: CodingFont;
  activeFamily?: string;
  showNames?: boolean;
  /** Browse mode: clicking a row previews the font in place instead of navigating. */
  selectable?: boolean;
};

const {
  fonts,
  baseFont,
  activeFamily,
  showNames = true,
  selectable = false,
} = Astro.props;

const selectAttrs = (font: CodingFont) =>
  selectable ? getSelectableFontTableRowAttrs(font) : {};
---

<div
  id="font-table"
  class="overflow-auto rounded-lg border border-slate-300 bg-white dark:border-slate-700 dark:bg-slate-950"
>
  <table class="w-full border-collapse text-left whitespace-nowrap">
    <thead>
      <tr
        class="border-b border-slate-300 text-xs text-slate-500 uppercase dark:border-slate-700 dark:text-slate-400"
      >
        <th class="px-3 py-2">Font Family</th>
        <th class="px-3 py-2">Preview</th>
        <th class="px-3 py-2">Actions</th>
      </tr>
    </thead>
    <tbody>
      {
        fonts.map((font) => (
          <tr
            data-search={getFontTableSearchValue(font)}
            {...selectAttrs(font)}
            class={`border-b border-slate-200 hover:bg-blue-50 dark:border-slate-800 dark:hover:bg-blue-950 ${
              selectable ? "cursor-pointer" : ""
            } ${activeFamily === font.family ? "bg-blue-100 dark:bg-blue-900/40" : ""}`}
          >
            <td
              class="max-w-36 truncate px-3 py-2 align-middle"
              style={getFontStyle(font)}
            >
              {selectable ? (
                <span class="block truncate">
                  {showNames ? getFontDisplayName(font) : "ABC abc 123"}
                </span>
              ) : (
                <a
                  class="block truncate hover:underline"
                  href={getFontPath(font.family)}
                >
                  {showNames ? getFontDisplayName(font) : "ABC abc 123"}
                </a>
              )}
            </td>
            <td class="px-3 py-2 align-middle">
              {selectable ? (
                <IconButton
                  data-compare-slug={getFontSlug(font.family)}
                  class="compare-link min-h-8 gap-2 rounded-md border border-slate-300 px-2 text-sm transition-transform active:scale-95 active:bg-slate-200 dark:border-slate-700 dark:active:bg-slate-700"
                  iconClass="h-4 w-4"
                  icon="icon-[lucide--columns-2]"
                  label="Compare"
                />
              ) : (
                // Hide on the base font's own row (no self-compare) and on the
                // currently-active row, whose Compare link would point to this page.
                shouldShowFontTableCompareLink({
                  font,
                  baseFont,
                  activeFamily,
                }) && (
                  <IconButton
                    href={getFontTableCompareHref(font, baseFont)}
                    class="min-h-8 gap-2 rounded-md border border-slate-300 px-2 text-sm transition-transform active:scale-95 active:bg-slate-200 dark:border-slate-700 dark:active:bg-slate-700"
                    iconClass="h-4 w-4"
                    icon="icon-[lucide--columns-2]"
                    label="Compare"
                  />
                )
              )}
            </td>
            <td class="px-3 py-2 align-middle">
              <ButtonGroup>
                {!font.isSystemFont && (
                  <>
                    <IconButton
                      href={font.siteUrl}
                      target="_blank"
                      divider
                      class="h-8 px-2"
                      iconClass="h-4 w-4"
                      icon="icon-[lucide--external-link]"
                      title="Visit site"
                    />
                    <IconButton
                      href={font.downloadUrl}
                      divider
                      class="h-8 px-2"
                      iconClass="h-4 w-4"
                      icon="icon-[lucide--download]"
                      title="Download"
                    />
                  </>
                )}
                <IconButton
                  href={getFontPath(font.family)}
                  class="h-8 px-2"
                  iconClass="h-4 w-4"
                  icon="icon-[lucide--maximize-2]"
                  title="Open font page"
                />
              </ButtonGroup>
            </td>
          </tr>
        ))
      }
    </tbody>
    <tfoot>
      <tr class="text-sm font-semibold">
        <th class="px-3 py-2">Total</th>
        <td class="px-3 py-2 align-middle" colspan="2">{fonts.length} fonts</td>
      </tr>
    </tfoot>
  </table>
</div>
